{
   "manifest_version":1,
   "version":"2.2.6",
   "type":"APP",
   "name":{
      "ja":"ガントチャートプラグイン",
      "en":"GanttChart plugin",
      "zh":"甘特图插件"
   },
   "description":{
      "ja":"これはガントチャートを表示するサンプルのプラグインです。",
      "en":"This is sample Gantt chart plugin.",
      "zh":"此插件是以甘特图为例示范插件的开发方法"
   },
   "icon":"img/icon.png",
   "homepage_url":{
      "ja":"https://cybozu.dev/ja/kintone/tips/development/plugins/sample-plugin/ganttchart-plugin/",
      "en":"https://cybozu.dev/ja/kintone/tips/development/plugins/sample-plugin/ganttchart-plugin/",
      "zh":"https://cybozudev.kf5.com/hc/kb/article/1007997/"
   },
   "desktop":{
      "js":[
         "thirdparties/jquery.min.js",
         "thirdparties/jquery.fn.gantt.min.js",
         "thirdparties/moment.min.js",
         "thirdparties/moment-timezone-with-data.min.js",
         "thirdparties/jquery-ui.min.js",
         "js/jquery.ui.datepicker-ja.min.js",
         "js/desktop-ganttchart.js"
      ],
      "css":[
         "thirdparties/jquerygantt/style.css",
         "thirdparties/jquery-ui/jquery-ui.css",
         "css/addin-style.css"
      ]
   },
   "mobile":{
      "js":[
         "thirdparties/jquery.min.js"
      ]
   },
   "config":{
      "html":"html/config.html",
      "js":[
         "thirdparties/jquery.min.js",
         "thirdparties/jsrender.min.js",
         "thirdparties/jqColorPicker.min.js",
         "js/config.js"
      ],
      "css":[
         "css/51-modern-default.css",
         "css/config.css"
      ],
      "required_params":[
         "ganttchartTitle",
         "ganttchartFrom",
         "ganttchartTo",
         "ganttchartColor",
         "ganttchartScall"
      ]
   }
}
